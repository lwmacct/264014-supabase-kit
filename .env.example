# VITE_SUPABASE_URL defaults to ./supabase at runtime, so subpath deployments
# like /dash/ can keep API calls under the same prefix.
VITE_SUPABASE_URL=./supabase
# VITE_SUPABASE_ANON_KEY can be passed at build time or injected at container startup.
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_VERSION=
